<section id="channels" class="section" aria-labelledby="channels-title">
  <div class="shell channel-layout">
    <div class="section-heading">
      <p class="eyebrow">Concept</p>
      <h2 id="channels-title">One can. Many strings.</h2>
      <p>
        A channel is a user-visible route. It can point a spoken message toward
        different kinds of outcomes without turning every route into an AI feature.
      </p>
      <ul class="endpoint-list" aria-label="Example conceptual destinations">
        <li><span class="endpoint endpoint--red" aria-hidden="true"></span>A recorder or personal log</li>
        <li><span class="endpoint endpoint--yellow" aria-hidden="true"></span>An automation or webhook</li>
        <li><span class="endpoint endpoint--blue" aria-hidden="true"></span>A service or assistant</li>
        <li><span class="endpoint endpoint--green" aria-hidden="true"></span>A person or shared conversation</li>
      </ul>
    </div>
    <div class="channel-graphic">
      <svg viewBox="0 0 720 460" role="img" aria-labelledby="channel-map-title channel-map-description">
        <title id="channel-map-title">One Talkcan interface connected to four channel destinations</title>
        <desc id="channel-map-description">A Talkcan symbol on the left branches through colored strings to a recorder, automation, service, and person.</desc>
        <image href="/brand/talkcan-symbol.svg" x="28" y="120" width="190" height="190" />
        <path class="route route--trunk" d="M218 215H316" />
        <path class="route route--red" d="M316 215C380 215 384 68 470 68" />
        <path class="route route--yellow" d="M316 215C395 215 390 166 520 166" />
        <path class="route route--blue" d="M316 215C395 215 390 276 520 276" />
        <path class="route route--green" d="M316 215C380 215 384 382 470 382" />
        <g class="route-label"><circle cx="484" cy="68" r="14" /><text x="510" y="77">Recorder</text></g>
        <g class="route-label"><circle cx="534" cy="166" r="14" /><text x="560" y="175">Automation</text></g>
        <g class="route-label"><circle cx="534" cy="276" r="14" /><text x="560" y="285">Service</text></g>
        <g class="route-label"><circle cx="484" cy="382" r="14" /><text x="510" y="391">Person</text></g>
      </svg>
    </div>
  </div>
</section>
